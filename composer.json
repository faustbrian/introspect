{
    "name": "cline/introspect",
    "description": "Runtime introspection helpers for PHP 8.4+ featuring trait detection, class hierarchy inspection, and reflection utilities",
    "license": "MIT",
    "keywords": [
        "php",
        "introspection",
        "reflection",
        "traits",
        "class-hierarchy",
        "runtime-analysis",
        "object-inspection"
    ],
    "authors": [
        {
            "name": "Brian Faust",
            "email": "brian@cline.sh"
        }
    ],
    "require": {
        "php": "^8.4.0"
    },
    "require-dev": {
        "cline/php-cs-fixer": "^1.0.4",
        "driftingly/rector-laravel": "^2.0.7",
        "ergebnis/composer-normalize": "^2.49@dev",
        "laravel/pint": "^1.25.1",
        "orchestra/testbench": "^10.6",
        "pestphp/pest": "^3.8.4",
        "pestphp/pest-plugin-laravel": "^3.2",
        "pestphp/pest-plugin-type-coverage": "^3.6.1",
        "phpstan/phpstan": "^2.1.30",
        "rector/rector": "^2.2.1",
        "symfony/var-dumper": "^7.3.4"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Cline\\Introspect\\": "src"
        },
        "files": [
            "src/Support/uses-trait.php",
            "src/Support/uses-traits.php",
            "src/Support/uses-any-trait.php",
            "src/Support/get-all-traits.php",
            "src/Support/implements-interface.php",
            "src/Support/extends-class.php",
            "src/Support/is-concrete.php",
            "src/Support/is-instantiable.php",
            "src/Support/has-method.php",
            "src/Support/method-is-public.php",
            "src/Support/get-public-methods.php",
            "src/Support/has-property.php",
            "src/Support/get-public-properties.php",
            "src/Support/class-basename.php",
            "src/Support/class-namespace.php",
            "src/Support/has-attribute.php",
            "src/Support/get-attributes.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true,
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "lint": "vendor/bin/php-cs-fixer fix",
        "refactor": "rector",
        "test": [
            "@test:lint",
            "@test:type-coverage",
            "@test:unit",
            "@test:types",
            "@test:refactor"
        ],
        "test:lint": "vendor/bin/php-cs-fixer check --diff",
        "test:refactor": "rector --dry-run",
        "test:type-coverage": "pest --parallel --exactly=100 --type-coverage",
        "test:types": "phpstan",
        "test:unit": "pest --parallel --exactly=100 --coverage"
    }
}
